#!/usr/bin/env bash
# Pre-commit hook: prevent committing secrets and large files

set -euo pipefail

MAX_FILE_SIZE_KB=500

# Check for common secret patterns
secret_patterns=(
  'password\s*='
  'secret\s*='
  'api_key\s*='
  'access_token\s*='
  'AKIA[0-9A-Z]{16}'
)

for pattern in "${secret_patterns[@]}"; do
  if git diff --cached --name-only | xargs grep -lEi "$pattern" 2>/dev/null; then
    echo "Error: possible secret detected matching pattern: $pattern"
    exit 1
  fi
done

# Check for large files
while IFS= read -r file; do
  size_kb=$(du -k "$file" 2>/dev/null | cut -f1)
  if [ "${size_kb:-0}" -gt "$MAX_FILE_SIZE_KB" ]; then
    echo "Error: $file is ${size_kb}KB (limit: ${MAX_FILE_SIZE_KB}KB)"
    exit 1
  fi
done < <(git diff --cached --name-only)

exit 0
